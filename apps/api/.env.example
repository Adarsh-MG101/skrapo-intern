# API server
HOST=localhost
PORT=3333
WEB_URL=http://localhost:3000

# MongoDB
# Local default: mongodb://127.0.0.1:27017/
MONGODB_URI=mongodb://127.0.0.1:27017/
MONGODB_DB_NAME=skrapo

# JWT
# Replace with a long random string in production
JWT_SECRET=skrapo-jwt-secret-change-in-production-2024
JWT_EXPIRES_IN=24h

# Security & Setup
# This key allows initial admin creation via API
ADMIN_SETUP_KEY=skrapo-emergency-setup-2024
CORS_ORIGINS=http://localhost:3000,http://localhost:3333

# Google Auth
GOOGLE_CLIENT_ID=530686063938-j5s9rmqvmn1cu5mgfcchmkk9c40khs30.apps.googleusercontent.com

# Firebase FCM (Backend Admin SDK)
FIREBASE_PROJECT_ID=skrapo-92d1f
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@skrapo-92d1f.iam.gserviceaccount.com
# Use \n for newlines in the private key string
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin Seed Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_PHONE=6366317690
ADMIN_NAME=Skrapo Admin

# Config & Timeouts
FEEDBACK_DELAY_MINUTES=30
PICKUP_REMINDER_MINUTES=60
BROADCAST_TIMEOUT_MINUTES=30
BROADCAST_MAX_RETRIES=0

# SMS Configuration
# Provider: mock (default) | twilio
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
